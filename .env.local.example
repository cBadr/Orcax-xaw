# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ---- App ----
# 32-byte hex key for AES-256-GCM (generate: openssl rand -hex 32)
ENCRYPTION_KEY=
# Public base URL (used for OAuth redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Gmail OAuth (Google Cloud Console) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Redirect URI to register in Google Cloud:
#   http://localhost:3000/api/auth/gmail/callback
#   https://YOUR-DOMAIN/api/auth/gmail/callback

# ---- Outlook OAuth (Azure App Registration) ----
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common
# Redirect URI to register in Azure:
#   http://localhost:3000/api/auth/outlook/callback
#   https://YOUR-DOMAIN/api/auth/outlook/callback

# ---- Cron auth (for Vercel Cron) ----
CRON_SECRET=
